# CelesTrak
CELESTRAK_BASE_URL=https://celestrak.org/SOCRATES/
TLE_SYNC_INTERVAL_MINUTES=30

# Space-Track (optional, for full debris catalog)
SPACETRACK_USER=your_email@example.com
SPACETRACK_PASS=your_password

# Conjunction threshold
CONJUNCTION_THRESHOLD_KM=5

# DB
POSTGRES_URL=postgresql://user:pass@localhost:5432/orbitguard

# Redis
REDIS_URL=redis://localhost:6379

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
PROPAGATOR_PORT=8001
